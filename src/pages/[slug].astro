---
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import BrowseSidebar from "../components/BrowseSidebar.astro";
import pages from "../data/pages.json";
import { pageDescription } from "../lib/meta.js";

export function getStaticPaths() {
  return pages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
const metaDescription = pageDescription(page.html);

// On the OpenFront Masters hub page, list the mirrored Masters pages by group.
const isMastersHub = page.slug === "OpenFront_Masters";
const mastersGroups = isMastersHub
  ? (() => {
      const masters = pages.filter((p) => (p.cats || []).includes("OpenFront Masters"));
      const pick = (sub) => masters.filter((p) => (p.cats || []).includes(sub)).sort((a, b) => a.title.localeCompare(b.title));
      return [
        { label: "OFM Official Tournaments", items: pick("OFM Official") },
        { label: "Community Tournaments", items: pick("Community") },
        { label: "Teams", items: pick("Teams") },
        { label: "Players", items: pick("Players") },
      ].filter((g) => g.items.length);
    })()
  : [];

// Hide MediaWiki maintenance categories; keep topical ones only.
const MAINT = /stub|broken file|hatnote|disambiguation|^all |^pages with|^articles with/i;
const topicalCats = (page.cats || []).filter((c) => !MAINT.test(c));
const isStub = (page.cats || []).some((c) => /stub/i.test(c));
---

<Layout title={`${page.title} — OpenFront Wiki`} description={metaDescription}>
  <SiteHeader />

  <div class="mx-auto grid max-w-7xl gap-8 px-4 py-8 sm:px-6 lg:grid-cols-[230px_minmax(0,1fr)] xl:grid-cols-[230px_minmax(0,1fr)_200px]">
    <!-- Left: browse + search -->
    <aside class="lg:sticky lg:top-20 lg:h-[calc(100vh-6rem)] lg:overflow-y-auto" data-pagefind-ignore>
      <details open>
        <summary class="mb-3 flex cursor-pointer list-none items-center justify-between text-xs font-semibold uppercase tracking-widest text-cyan-glow lg:cursor-default">
          Browse Pages <span class="lg:hidden">▾</span>
        </summary>
        <BrowseSidebar currentSlug={page.slug} />
      </details>
    </aside>

    <!-- Center: article -->
    <main class="min-w-0">
      <nav class="mb-4 flex items-center gap-2 text-xs text-dawn/50" data-pagefind-ignore>
        <a href="/" class="hover:text-aquarius">Home</a>
        <span>/</span>
        <a href="/all" class="hover:text-aquarius">All Pages</a>
        <span>/</span>
        <span class="text-dawn">{page.title}</span>
      </nav>

      <div class="flex flex-wrap items-center gap-3">
        <h1 class="font-display text-3xl font-bold tracking-wide text-white sm:text-4xl">
          {page.title}
        </h1>
        {
          isStub && (
            <span class="rounded-full border border-masters/40 bg-masters/10 px-2.5 py-0.5 text-xs font-semibold text-masters">
              Stub
            </span>
          )
        }
      </div>

      {
        topicalCats.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-2">
            {topicalCats.map((c) => (
              <span class="rounded-full border border-white/10 bg-navy-700/60 px-2.5 py-0.5 text-xs font-medium text-dawn/80">
                {c}
              </span>
            ))}
          </div>
        )
      }

      <div class="mt-5 h-px w-full bg-gradient-to-r from-malibu/50 via-white/10 to-transparent"></div>

      <article class="wiki-content mt-6" set:html={page.html} data-pagefind-body />

      {isMastersHub && mastersGroups.length > 0 && (
        <div class="wiki-content mt-8">
          {mastersGroups.map((g) => (
            <section class="mb-6">
              <h2 class="font-display text-xl font-bold text-white">{g.label}</h2>
              <ul class="mt-2 grid gap-1 sm:grid-cols-2">
                {g.items.map((p) => (
                  <li>
                    <a href={`/${p.slug}`} class="text-aquarius hover:text-white">{p.title}</a>
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      )}

      <div class="mt-10 border-t border-white/10 pt-5 text-xs text-dawn/50">
        {page.source === "liquipedia" ? (
          <span>
            This page uses material from
            <a href={page.sourceUrl} target="_blank" rel="noopener noreferrer" class="text-aquarius hover:text-white">Liquipedia</a>,
            licensed under
            <a href="https://creativecommons.org/licenses/by-sa/3.0/" target="_blank" rel="noopener noreferrer" class="text-aquarius hover:text-white">CC BY-SA 3.0</a>.
          </span>
        ) : (
          <span>
            Content from the OpenFront community wiki, available under
            <a href="https://creativecommons.org/licenses/by-sa/4.0/" target="_blank" rel="noopener noreferrer" class="text-aquarius hover:text-white">CC BY-SA 4.0</a>.
          </span>
        )}
      </div>
    </main>

    <!-- Right: table of contents -->
    {
      page.headings.length > 1 && (
        <aside class="hidden xl:block" data-pagefind-ignore>
          <div class="sticky top-20">
            <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-cyan-glow">
              On this page
            </p>
            <ul class="space-y-1.5 border-l border-white/10 text-sm">
              {page.headings.map((h) => (
                <li>
                  <a
                    href={`#${h.id}`}
                    class:list={[
                      "-ml-px block border-l-2 border-transparent py-0.5 text-dawn/70 transition-colors hover:border-malibu hover:text-white",
                      h.level === 3 ? "pl-6" : "pl-3",
                    ]}
                  >
                    {h.text}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </aside>
      )
    }
  </div>

  <SiteFooter />
</Layout>

<script>
  // Liquipedia toggle-areas (group/bracket view switchers): Liquipedia shows one
  // view and switches via JS; without it every view stacks. Re-implement the
  // switch so only the active view shows and the pills work. No-op on pages
  // without toggle-areas.
  const SCOPE = '[data-toggle-area]:not([data-toggle-area=""])';
  document.querySelectorAll(SCOPE).forEach((area) => {
    const n = area.getAttribute("data-toggle-area");
    const own = (sel: string) =>
      Array.from(area.querySelectorAll(sel)).filter((el) => el.closest(SCOPE) === area);
    const contents = own("[data-toggle-area-content]") as HTMLElement[];
    const pills = own(`[data-toggle-area-btn="${n}"]`) as HTMLElement[];
    if (contents.length < 2 && pills.length < 2) return; // nothing to switch
    const active = pills.find((p) => p.classList.contains("switch-pill-option-active"));
    let val = active?.getAttribute("data-switch-value") ?? "1";
    const apply = () => {
      contents.forEach((c) => {
        c.style.display = c.getAttribute("data-toggle-area-content") === val ? "" : "none";
      });
      pills.forEach((p) =>
        p.classList.toggle(
          "switch-pill-option-active",
          p.getAttribute("data-switch-value") === val,
        ),
      );
    };
    pills.forEach((p) =>
      p.addEventListener("click", () => {
        val = p.getAttribute("data-switch-value") ?? val;
        apply();
      }),
    );
    apply();
  });
</script>
