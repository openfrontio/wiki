---
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import pages from "../data/pages.json";

export function getStaticPaths() {
  return pages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;

// Alphabetical list for the browse sidebar.
const allPages = pages
  .map((p) => ({ slug: p.slug, title: p.title }))
  .sort((a, b) => a.title.localeCompare(b.title));

// Hide MediaWiki maintenance categories; keep topical ones only.
const MAINT = /stub|broken file|hatnote|disambiguation|^all |^pages with|^articles with/i;
const topicalCats = (page.cats || []).filter((c) => !MAINT.test(c));
const isStub = (page.cats || []).some((c) => /stub/i.test(c));
---

<Layout title={`${page.title} — OpenFront Wiki`}>
  <SiteHeader />

  <div class="mx-auto grid max-w-7xl gap-8 px-4 py-8 sm:px-6 lg:grid-cols-[230px_minmax(0,1fr)] xl:grid-cols-[230px_minmax(0,1fr)_200px]">
    <!-- Left: browse + search -->
    <aside class="lg:sticky lg:top-20 lg:h-[calc(100vh-6rem)] lg:overflow-y-auto">
      <details open>
        <summary class="mb-3 flex cursor-pointer list-none items-center justify-between text-xs font-semibold uppercase tracking-widest text-cyan-glow lg:cursor-default">
          Browse Pages
          <span class="lg:hidden">▾</span>
        </summary>
        <input
          id="page-filter"
          type="search"
          placeholder="Filter pages…"
          autocomplete="off"
          class="mb-3 w-full rounded-lg border border-white/10 bg-navy-700/70 px-3 py-2 text-sm text-white placeholder:text-dawn/40 focus:border-malibu/60 focus:outline-none"
        />
        <ul id="page-list" class="space-y-0.5 text-sm">
          {
            allPages.map((p) => (
              <li>
                <a
                  href={`/${p.slug}`}
                  data-title={p.title.toLowerCase()}
                  class:list={[
                    "block rounded-md px-2.5 py-1.5 transition-colors hover:bg-white/5 hover:text-white",
                    p.slug === page.slug
                      ? "bg-malibu/15 font-semibold text-aquarius"
                      : "text-dawn/80",
                  ]}
                >
                  {p.title}
                </a>
              </li>
            ))
          }
        </ul>
      </details>
    </aside>

    <!-- Center: article -->
    <main class="min-w-0">
      <nav class="mb-4 flex items-center gap-2 text-xs text-dawn/50">
        <a href="/" class="hover:text-aquarius">Home</a>
        <span>/</span>
        <a href="/all" class="hover:text-aquarius">All Pages</a>
        <span>/</span>
        <span class="text-dawn">{page.title}</span>
      </nav>

      <div class="flex flex-wrap items-center gap-3">
        <h1 class="font-display text-3xl font-bold tracking-wide text-white sm:text-4xl">
          {page.title}
        </h1>
        {
          isStub && (
            <span class="rounded-full border border-masters/40 bg-masters/10 px-2.5 py-0.5 text-xs font-semibold text-masters">
              Stub
            </span>
          )
        }
      </div>

      {
        topicalCats.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-2">
            {topicalCats.map((c) => (
              <span class="rounded-full border border-white/10 bg-navy-700/60 px-2.5 py-0.5 text-xs font-medium text-dawn/80">
                {c}
              </span>
            ))}
          </div>
        )
      }

      <div class="mt-5 h-px w-full bg-gradient-to-r from-malibu/50 via-white/10 to-transparent"></div>

      <article class="wiki-content mt-6" set:html={page.html} />

      <div class="mt-10 border-t border-white/10 pt-5 text-xs text-dawn/50">
        Content from the OpenFront community wiki, available under
        <a
          href="https://creativecommons.org/licenses/by-sa/4.0/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-aquarius hover:text-white">CC BY-SA 4.0</a
        >.
      </div>
    </main>

    <!-- Right: table of contents -->
    {
      page.headings.length > 1 && (
        <aside class="hidden xl:block">
          <div class="sticky top-20">
            <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-cyan-glow">
              On this page
            </p>
            <ul class="space-y-1.5 border-l border-white/10 text-sm">
              {page.headings.map((h) => (
                <li>
                  <a
                    href={`#${h.id}`}
                    class:list={[
                      "-ml-px block border-l-2 border-transparent py-0.5 text-dawn/70 transition-colors hover:border-malibu hover:text-white",
                      h.level === 3 ? "pl-6" : "pl-3",
                    ]}
                  >
                    {h.text}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </aside>
      )
    }
  </div>

  <SiteFooter />
</Layout>

<script>
  // Client-side filter for the browse sidebar.
  const input = document.getElementById("page-filter") as HTMLInputElement | null;
  const list = document.getElementById("page-list");
  input?.addEventListener("input", () => {
    const q = input.value.trim().toLowerCase();
    list?.querySelectorAll("li").forEach((li) => {
      const t = li.querySelector("a")?.dataset.title ?? "";
      (li as HTMLElement).style.display = t.includes(q) ? "" : "none";
    });
  });
</script>
