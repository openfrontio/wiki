---
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import pages from "../data/pages.json";

const sorted = [...pages].sort((a, b) => a.title.localeCompare(b.title));
const groups = new Map<string, { slug: string; title: string }[]>();
for (const p of sorted) {
  const letter = /[a-z]/i.test(p.title[0]) ? p.title[0].toUpperCase() : "#";
  if (!groups.has(letter)) groups.set(letter, []);
  groups.get(letter)!.push({ slug: p.slug, title: p.title });
}
---

<Layout title="All Pages — OpenFront Wiki" description="Browse every article in the OpenFront community wiki — game mechanics, units, maps, tournaments, and more.">
  <SiteHeader />

  <main class="mx-auto max-w-5xl px-4 py-10 sm:px-6">
    <h1 class="font-display text-3xl font-bold tracking-wide text-white sm:text-4xl">
      All Pages
    </h1>
    <p class="mt-2 text-sm text-dawn/70">
      Every article in the OpenFront Wiki — {pages.length} pages.
    </p>

    <input
      id="all-filter"
      type="search"
      placeholder="Search all pages…"
      autocomplete="off"
      class="mt-6 w-full rounded-lg border border-white/10 bg-navy-700/70 px-4 py-3 text-white placeholder:text-dawn/40 focus:border-malibu/60 focus:outline-none"
    />

    <div id="all-groups" class="mt-8 space-y-8">
      {
        [...groups.entries()].map(([letter, items]) => (
          <section data-group={letter}>
            <h2 class="font-display text-xl font-bold text-aquarius">{letter}</h2>
            <div class="mt-3 grid grid-cols-1 gap-2 sm:grid-cols-2 lg:grid-cols-3">
              {items.map((p) => (
                <a
                  href={`/${p.slug}`}
                  data-title={p.title.toLowerCase()}
                  class="rounded-lg border border-white/10 bg-navy-700/50 px-3.5 py-2.5 text-sm font-medium text-dawn transition-all hover:-translate-y-0.5 hover:border-malibu/50 hover:bg-navy-600 hover:text-white"
                >
                  {p.title}
                </a>
              ))}
            </div>
          </section>
        ))
      }
    </div>
    <p id="no-results" class="mt-8 hidden text-sm text-dawn/60">No pages match your search.</p>
  </main>

  <SiteFooter />
</Layout>

<script>
  const input = document.getElementById("all-filter") as HTMLInputElement | null;
  const groups = document.querySelectorAll<HTMLElement>("#all-groups section");
  const empty = document.getElementById("no-results");
  input?.addEventListener("input", () => {
    const q = input.value.trim().toLowerCase();
    let any = false;
    groups.forEach((section) => {
      let shown = 0;
      section.querySelectorAll<HTMLElement>("a[data-title]").forEach((a) => {
        const match = (a.dataset.title ?? "").includes(q);
        a.style.display = match ? "" : "none";
        if (match) shown++;
      });
      section.style.display = shown ? "" : "none";
      if (shown) any = true;
    });
    empty?.classList.toggle("hidden", any);
  });
</script>
